prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: absl_log
Description: Abseil log library
URL: https://abseil.io/
Version: 20240722

Libs: "-L${libdir}"
Requires: absl_log_internal_log_impl = 20240722, absl_vlog_is_on = 20240722
Cflags: "-I${includedir}" -Wno-float-conversion -Wno-implicit-float-conversion -Wno-implicit-int-float-conversion -Wno-unknown-warning-option -DNOMINMAX
